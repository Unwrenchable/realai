# ============================================================================
# Frontend (Vercel)
# ============================================================================
NEXT_PUBLIC_API_URL=https://realai-api.onrender.com

# ============================================================================
# Backend (Render / FastAPI)
# ============================================================================
OPENAI_API_KEY=
REALAI_MODEL=realai-1.0
ENV=production
CORS_ALLOWED_ORIGINS=https://realai.vercel.app,https://your-custom-domain.com
PORT=8000
WEB_CONCURRENCY=1

# ============================================================================
# Deployment (Render/Vercel)
# ============================================================================
# Set these in Render and Vercel dashboard, not in .env
# - Render Health Check: /health
# - Render Timeout: 1000ms
# - Render Failure Threshold: 3

# ============================================================================
# Development (local)
# ============================================================================
REALAI_API_BASE=http://localhost:8000

# ============================================================================
# Database / Storage (optional)
# ============================================================================
# REALAI_DB_PATH: defaults to ~/.realai/conversations.db
# REALAI_DATA_DIR: defaults to ~/.realai

# ============================================================================
# Optional: Billing & Analytics
# ============================================================================
# BILLING_ENABLED=false
# ANALYTICS_ENABLED=false

# ============================================================================
# Optional: Training Pipeline
# ============================================================================
# TRAINING_DATASET_PATH=
# TRAINING_MODEL_NAME=realai-1.0

CORS_ALLOWED_ORIGINS=*
PORT=8000